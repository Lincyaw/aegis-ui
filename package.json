{
  "name": "aegis",
  "version": "0.0.0",
  "private": true,
  "description": "AegisLab shared design system monorepo: packages/ui (published) + apps/playground (dev only).",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm -F @OperationsPAI/playground dev",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:css": "turbo run lint:css",
    "format": "prettier --write \"{packages,apps}/**/*.{ts,tsx,css,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{packages,apps}/**/*.{ts,tsx,css,json,md}\" \"*.{json,md}\"",
    "check": "pnpm type-check && pnpm lint && pnpm lint:css && pnpm format:check",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-unused-imports": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.15.3"
}
