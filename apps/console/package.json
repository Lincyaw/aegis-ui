{
  "name": "@lincyaw/console",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "bundle:prepare": "vite build",
    "bundle:host": "pnpm bundle:prepare && node server/bundle.mjs host",
    "bundle:linux-x64": "pnpm bundle:prepare && node server/bundle.mjs linux-x64",
    "bundle:linux-arm64": "pnpm bundle:prepare && node server/bundle.mjs linux-arm64",
    "bundle:macos-x64": "pnpm bundle:prepare && node server/bundle.mjs macos-x64",
    "bundle:macos-arm64": "pnpm bundle:prepare && node server/bundle.mjs macos-arm64",
    "bundle:windows-x64": "pnpm bundle:prepare && node server/bundle.mjs windows-x64",
    "bundle:all": "pnpm bundle:prepare && node server/bundle.mjs linux-x64 && node server/bundle.mjs linux-arm64 && node server/bundle.mjs macos-x64 && node server/bundle.mjs macos-arm64 && node server/bundle.mjs windows-x64",
    "changelog": "git-cliff -o CHANGELOG.md",
    "release": "pnpm changelog && git add CHANGELOG.md && git commit -m 'chore(release): update changelog'"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@dagrejs/dagre": "^3.0.0",
    "@duckdb/duckdb-wasm": "^1.30.0",
    "@finos/perspective": "^3.8.0",
    "@finos/perspective-viewer": "^3.8.0",
    "@finos/perspective-viewer-d3fc": "^3.8.0",
    "@finos/perspective-viewer-datagrid": "^3.8.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lincyaw/aegis-ui": "workspace:*",
    "@lincyaw/portal": "^2.0.0",
    "@tanstack/react-query": "^5.28.0",
    "@types/react-window": "^2.0.0",
    "ansi-to-html": "^0.7.2",
    "antd": "^5.15.0",
    "apache-arrow": "^21.1.0",
    "arrow-js-ffi": "^0.4.3",
    "axios": "^1.6.7",
    "chroma-js": "^3.2.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "fzstd": "^0.1.1",
    "lz4js": "^0.2.0",
    "nuqs": "^2.8.9",
    "parquet-wasm": "^0.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-view": "^1.21.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "react-window": "^2.2.5",
    "reactflow": "^11.11.4",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-unused-imports": "^3.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "vite": "^5.1.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
